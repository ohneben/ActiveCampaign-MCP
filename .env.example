# =====================================================================
# ActiveCampaign MCP — copy this file to `.env` and fill in the two
# required values below. `.env` is git-ignored — never commit real secrets.
# =====================================================================

# ─── Required: ActiveCampaign API credentials ────────────────────────
# 1) Your account's API URL. Copy it EXACTLY from ActiveCampaign →
#    Settings → Developer (the "API Access" box). It looks like:
#    https://your-account.api-us1.com/api/3
#    Non-US accounts and custom domains use a different host — always use
#    the URL your account shows, don't assume "api-us1".
ACTIVECAMPAIGN_API_URL=https://your-account.api-us1.com/api/3

# 2) Your API token (same Developer screen). Paste the value only.
ACTIVECAMPAIGN_API_TOKEN=your-api-token

# ─── Optional: transport ─────────────────────────────────────────────
# "stdio" (Claude Desktop / local launchers) or "http" (hosted / Docker).
# The Docker image defaults to http.
MCP_TRANSPORT=http

# HTTP transport settings (ignored for stdio).
PORT=8765
HOST=0.0.0.0
MCP_HTTP_PATH=/mcp

# Protect the exposed HTTP endpoint with a bearer token. Strongly recommended
# if the container is reachable from anything but localhost. Leave empty to
# disable (fine for the default 127.0.0.1-only bind).
MCP_SHARED_TOKEN=

# ─── Optional: resilience & throttling ───────────────────────────────
# ActiveCampaign allows 5 requests / second per account (shared across all
# keys). The server self-throttles just below that. Set MAX_REQUESTS=0 to
# disable client-side throttling entirely (retries still cover 429s).
ACTIVECAMPAIGN_MAX_REQUESTS=4
ACTIVECAMPAIGN_RATE_WINDOW_MS=1000

# Automatic retries on 429 / 5xx / network errors (honors Retry-After).
ACTIVECAMPAIGN_MAX_RETRIES=3

# Per-attempt request timeout in milliseconds.
ACTIVECAMPAIGN_TIMEOUT_MS=30000

# ─── Optional: tool-surface controls ─────────────────────────────────
# The server exposes ~325 tools by default. Narrow that per deployment:
#
# Only expose these resource groups (comma-separated group keys; see
# `npm run list-tools` for the full list, e.g. contacts,deals,lists,tags):
# ACTIVECAMPAIGN_INCLUDE_GROUPS=contacts,deals,lists,tags,fields,campaigns
#
# Hide these resource groups:
# ACTIVECAMPAIGN_EXCLUDE_GROUPS=ecomOrders,ecomCustomers,siteTracking
#
# Read-only mode: expose ONLY 🟢 read-only tools — every write/destructive
# tool (and GraphQL) is hidden. Great for analytics/reporting deployments.
ACTIVECAMPAIGN_READ_ONLY=false

# Expose the Ecommerce GraphQL passthrough tool (POST /api/3/ecom/graphql).
ACTIVECAMPAIGN_ENABLE_GRAPHQL=true
# Override the GraphQL endpoint if needed (defaults to <account>/api/3/ecom/graphql):
# ACTIVECAMPAIGN_GRAPHQL_URL=

# Truncate any single tool response longer than this many characters, so one
# huge list can't swamp the model's context. 0 = never truncate.
ACTIVECAMPAIGN_MAX_RESPONSE_CHARS=0

# ─── Optional: override the bundled specs ────────────────────────────
# Point at a directory containing your own OpenAPI JSON/YAML files (must use
# the same filenames as spec/). Only set this to test a newer API definition.
# ACTIVECAMPAIGN_SPEC_DIR=/abs/path/to/spec
